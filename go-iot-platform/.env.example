# Django backend
DJANGO_BASE_URL=http://localhost:8000/api
# Service account credentials (created with: python manage.py create_service_user --password ...)
DJANGO_SERVICE_USER=iot-ingest
DJANGO_SERVICE_PASS=

# MQTT broker
MQTT_BROKER=tcp://localhost:1883
MQTT_USER=
MQTT_PASS=
# Optional: client ID custom; default = "go-ingest-<unix-nano>" (unic per instanță, OK pentru shared subs)
MQTT_CLIENT_ID=
# MQTT Bridge client ID — default = "mqtt-bridge-<unix-nano>" (Faza 2.2)
MQTT_BRIDGE_CLIENT_ID=

# InfluxDB
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=
INFLUX_ORG=
INFLUX_BUCKET=

# JWT (must match Django JWT_SECRET; used by API handler to verify tokens)
JWT_SECRET=

# CORS allowlist (added in step 0.4) — comma-separated origins
ALLOWED_ORIGINS=

# Redis cache device→tenant (Faza 2.4) — opțional; lipsa → fallback la Django per-message
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0

# Influx buckets per plan de tenant (Faza 2.7) — default-uri dacă lipsesc: iot-free / iot-pro / iot-enterprise
# Retention recomandat: iot-free=7d, iot-pro=90d, iot-enterprise=730d (configurat în InfluxDB la creare)
INFLUX_BUCKET_FREE=iot-free
INFLUX_BUCKET_PRO=iot-pro
INFLUX_BUCKET_ENTERPRISE=iot-enterprise
