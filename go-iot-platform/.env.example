# Django backend
DJANGO_BASE_URL=http://localhost:8000/api
# Service account credentials (created with: python manage.py create_service_user --password ...)
DJANGO_SERVICE_USER=iot-ingest
DJANGO_SERVICE_PASS=

# MQTT broker
MQTT_BROKER=tcp://localhost:1883
MQTT_USER=
MQTT_PASS=

# InfluxDB
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=
INFLUX_ORG=
INFLUX_BUCKET=

# JWT (must match Django JWT_SECRET; used by API handler to verify tokens)
JWT_SECRET=

# CORS allowlist (added in step 0.4) — comma-separated origins
ALLOWED_ORIGINS=

# Redis cache device→tenant (Faza 2.4) — opțional; lipsa → fallback la Django per-message
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0
