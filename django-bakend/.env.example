# Django
DJANGO_SECRET_KEY=

# Service account pentru Go ingest — trebuie să coincidă cu go-iot-platform/.env
DJANGO_SERVICE_USER=iot-ingest
DJANGO_SERVICE_PASS=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# MySQL
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# JWT (must match KONG_VARS_KONG_JWT_SECRET in Kong env and JWT_SECRET in go-iot-platform/.env)
JWT_SECRET=

# Redis URL pentru pub/sub cache invalidation (Faza 2.4) — opțional
# Format: redis://[:password]@host:port/db ; password URL-encoded (slash = %2F)
REDIS_URL=

# MQTT HTTP Hook secret — shared secret trimis de EMQX în X-Hook-Secret header (Faza 2.1)
# Dacă e gol, verificarea e dezactivată (dev mode).
MQTT_HOOK_SECRET=
